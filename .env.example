# Application
APP_NAME=profeta
ENV=prod
LOG_LEVEL=INFO
PORT=8000

# Telegram bot
TELEGRAM_BOT_TOKEN=__REPLACE_WITH_TELEGRAM_BOT_TOKEN__
BOT_USERNAME=__REPLACE_WITH_TELEGRAM_BOT_USERNAME__

# AI
OPENAI_API_KEY=__REPLACE_WITH_OPENAI_API_KEY__
OPENAI_EXPLANATION_MODEL=gpt-5.4
DEFAULT_EXPLANATION_DEPTH=balanced

# Database
# DATABASE_URL é gerenciado automaticamente via config.py com path absoluto derivado da localização do código.
# Descomente APENAS para trocar para PostgreSQL ou especificar path customizado:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/profeta
# DATABASE_URL=sqlite+aiosqlite:////opt/profeta/current/data/profeta.db

# Session backend (opcional)
# Vazio = MemoryBackend in-process (single-instance, padrão dev/test).
# Configurado = RedisBackend persistente (multi-instância, multi-canal).
# Fallback automático para Memory se Redis não estiver disponível.
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=rediss://user:pass@your-redis-host:6380/0  # TLS

# Asaas
ASAAS_API_KEY=__REPLACE_WITH_ASAAS_API_KEY__
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_SECRET=__REPLACE_WITH_ASAAS_WEBHOOK_SECRET__
ASAAS_WEBHOOK_TOKEN=__REPLACE_WITH_ASAAS_WEBHOOK_TOKEN__
ASAAS_PAYMENT_LINK_ID=__REPLACE_WITH_ASAAS_PAYMENT_LINK_ID__
ASAAS_PAYMENT_LINK_URL=__REPLACE_WITH_ASAAS_PAYMENT_LINK_URL__

# App URLs and schedule
PUBLIC_BASE_URL=https://profeta.example.com
TIMEZONE=America/Sao_Paulo
DAILY_SEND_HOUR=8

# Audio
TTS_VOICE=pt-BR-AntonioNeural
TTS_RATE=-15%

# Feature flags
FEATURE_INLINE_ACTIONS=true
FEATURE_FAVORITES=true
FEATURE_JOURNEYS=true
FEATURE_PREMIUM_PRAYER=true
